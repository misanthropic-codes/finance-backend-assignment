{
  "info": {
    "_postman_id": "0dc4e8d3-4b5a-4de1-9b1f-3b8aa1d9aa11",
    "name": "Finance Backend RBAC Auto Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Automated Postman collection for Finance Backend RBAC matrix coverage. Run in order using Collection Runner."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  pm.collectionVariables.set('runId', String(Date.now()));",
          "}",
          "if (!pm.collectionVariables.get('createUserEmail')) {",
          "  pm.collectionVariables.set('createUserEmail', `postman-user-${pm.collectionVariables.get('runId')}@example.com`);",
          "}",
          "if (!pm.collectionVariables.get('recordCategory')) {",
          "  pm.collectionVariables.set('recordCategory', `Postman-${pm.collectionVariables.get('runId')}`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 Setup",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Health payload has status ok', function () {",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('tokenAdmin', body.token);",
                  "pm.collectionVariables.set('adminUserId', body.user.id);",
                  "pm.test('Admin token captured', function () {",
                  "  pm.expect(pm.collectionVariables.get('tokenAdmin')).to.be.a('string').and.not.empty;",
                  "});"
                ]
